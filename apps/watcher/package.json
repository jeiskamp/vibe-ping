{
  "name": "@vibeping/watcher",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop watcher app for VibePing Discord presence updates.",
  "author": "VibePing Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/justincoolio/vibe-ping.git"
  },
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-renderer-assets.cjs",
    "ensure-electron": "node scripts/ensure-electron.cjs",
    "package": "pnpm run build && electron-builder --publish never",
    "package:dir": "pnpm run build && electron-builder --dir --publish never",
    "package:verify": "node scripts/verify-package-output.cjs",
    "release:smoke": "pnpm run package:dir && pnpm run package:verify",
    "start": "pnpm run build && pnpm run ensure-electron && electron dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "@types/node": "^24.0.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "vitest": "^2.1.8"
  }
}
